<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.warehouse.WarehouseController"
            style="-fx-background-color: #f5f6fa;">

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent;">
            <VBox spacing="12" style="-fx-padding: 15;">
                <Label text="Quản lý tồn kho nguyên liệu" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Tổng quan tồn kho"/>
                
                <TextField fx:id="txtSearch" promptText="Tìm kiếm nguyên liệu..."/>
                
                <TableView fx:id="tblSummary" prefHeight="250" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colName" text="Nguyên liệu" prefWidth="200"/>
                        <TableColumn fx:id="colUnit" text="Đơn vị" prefWidth="80"/>
                        <TableColumn fx:id="colTotal" text="Tổng tồn" prefWidth="100"/>
                        <TableColumn fx:id="colExpiry" text="Hạn gần nhất" prefWidth="120"/>
                        <TableColumn fx:id="colStorage" text="Bảo quản" prefWidth="150"/> 
                        <TableColumn fx:id="colSummaryStatus" text="Trạng thái" prefWidth="120"/>
                    </columns>
                </TableView>

                <Label text="Chi tiết lô (FIFO)"/>
                <TableView fx:id="tblDetailLots" prefHeight="250" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLotId" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="colLotName" text="Nguyên liệu" prefWidth="150"/>
                        <TableColumn fx:id="colLotUnit" text="Đơn vị" prefWidth="75.0" />
                        <TableColumn fx:id="colSupplier" text="Nhà cung cấp" prefWidth="150"/>
                        <TableColumn fx:id="colImportDate" text="Ngày Nhập" prefWidth="120"/>
                        <TableColumn fx:id="colLotExpiry" text="Hạn dùng" prefWidth="100"/>
                        <TableColumn fx:id="colLotStorage" text="Bảo quản" prefWidth="120"/>
                        <TableColumn fx:id="colRemain" text="Còn lại" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </ScrollPane>
    </center>

    <right>
        <VBox spacing="12" prefWidth="300" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ddd;">
            <Label text="Cập nhật kho" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Label text="Tên nguyên liệu"/><TextField fx:id="txtMaterialName" promptText="Ví dụ: Sữa tươi"/>
            <Label text="Đơn vị"/><ComboBox fx:id="cbUnit" maxWidth="Infinity" promptText="Chọn đơn vị"/>
            <Label text="Số lượng"/><TextField fx:id="txtQuantity" promptText="Ví dụ: 100"/>
            <Label text="Hạn sử dụng"/><DatePicker fx:id="dpExpiryDate" maxWidth="Infinity"/>
            <Label text="Nhà cung cấp"/><TextField fx:id="txtSupplierName" promptText="Nhập tên nhà cung cấp"/>
            <Separator/>
            <Button fx:id="btnAdd" text="Nhập kho" maxWidth="Infinity" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="btnUpdate" text="Cập nhật" maxWidth="Infinity" onAction="#handleUpdate" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="btnDelete" text="Xóa nguyên liệu" maxWidth="Infinity" onAction="#handleDelete" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Thêm loại nguyên liệu" onAction="#openNewIngredientDialog" 
			        style="-fx-background-color: #17a2b8; -fx-text-fill: white; -fx-font-weight: bold;" 
			        maxWidth="Infinity"/>
        <Separator/>
            <Button fx:id="btnRefresh" text="Làm mới" maxWidth="Infinity" onAction="#handleRefresh" style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </right>
</BorderPane>