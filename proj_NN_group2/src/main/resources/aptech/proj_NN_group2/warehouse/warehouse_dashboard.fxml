<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720.0" prefWidth="1250.0"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.warehouse.WarehouseController"
            style="-fx-background-color: #f5f7fa;">

    <!-- ===== TOP BAR ===== -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-padding: 12; -fx-background-color: white; -fx-border-color: #e5e7eb;">

            <!-- SEARCH -->
            <TextField fx:id="txtSearch"
                       promptText="🔍 Search ingredients..."
                       prefWidth="260"
                       style="-fx-background-radius: 20;
                              -fx-border-radius: 20;
                              -fx-border-color: #d1d5db;
                              -fx-padding: 6 12;" />

            <Region HBox.hgrow="ALWAYS" />

            <!-- BUTTONS -->
            <Button text="Add" onAction="#handleAdd"
                    style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-background-radius: 8;"/>

            <Button text="Update" onAction="#handleUpdate"
                    style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8;"/>

            <Button text="Delete" onAction="#handleDelete"
                    style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 8;"/>

            <Button text="Refresh" onAction="#handleRefresh"
                    style="-fx-background-radius: 8;"/>

            <Button text="Export" onAction="#handleExport"
                    style="-fx-background-radius: 8;"/>

            <Button text="Export Requests" onAction="#handleViewExportRequests"
                    style="-fx-background-radius: 8;"/>

            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-background-radius: 8;"/>

        </HBox>
    </top>

    <!-- ===== CENTER ===== -->
    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- ===== SUMMARY ===== -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 10;
                         -fx-background-radius: 12;
                         -fx-border-color: #e5e7eb;">

                <Label text="Inventory Summary"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <TableView fx:id="tblSummary" prefHeight="220">
                    <columns>
                        <TableColumn fx:id="colName" text="Ingredient" prefWidth="150"/>
                        <TableColumn fx:id="colUnit" text="Unit" prefWidth="90"/>
                        <TableColumn fx:id="colTotal" text="Stock" prefWidth="100"/>
                        <TableColumn fx:id="colExpiry" text="Nearest Expiry" prefWidth="150"/>
                        <TableColumn fx:id="colStorage" text="Storage" prefWidth="150"/>
                        <TableColumn fx:id="colSummaryStatus" text="Status" prefWidth="140"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ===== LOT ===== -->
            <VBox spacing="10"
                  style="-fx-background-color: white;
                         -fx-padding: 10;
                         -fx-background-radius: 12;
                         -fx-border-color: #e5e7eb;">

                <Label text="Lot Details"
                       style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

                <TableView fx:id="tblLots" prefHeight="260">
                    <columns>
                        <TableColumn fx:id="colLotId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colLotName" text="Ingredient" prefWidth="150"/>
                        <TableColumn fx:id="colSupplier" text="Supplier" prefWidth="140"/>
                        <TableColumn fx:id="colImport" text="Import Date" prefWidth="120"/>
                        <TableColumn fx:id="colLotExpiry" text="Expiry" prefWidth="120"/>
                        <TableColumn fx:id="colRemain" text="Remaining" prefWidth="100"/>
                        <TableColumn fx:id="colLotStorage" text="Storage" prefWidth="140"/>
                        <TableColumn fx:id="colStatus" text="Status" prefWidth="130"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </center>

    <!-- ===== FORM ===== -->
    <bottom>
        <VBox spacing="10"
              style="-fx-padding: 15;
                     -fx-background-color: white;
                     -fx-border-color: #e5e7eb;">

            <Label text="Manage Inventory"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;"/>

            <GridPane hgap="12" vgap="10">

                <columnConstraints>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                    <ColumnConstraints percentWidth="15"/>
                    <ColumnConstraints percentWidth="35"/>
                </columnConstraints>

                <!-- ROW 1 -->
                <Label text="Ingredient:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtMaterialName" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Quantity:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="txtQuantity" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                <!-- ROW 2 -->
                <Label text="Unit:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="cbUnit" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Supplier:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="txtSupplierName" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                <!-- ROW 3 -->
                <Label text="Expiry Date:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dpExpiryDate" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            </GridPane>

        </VBox>
    </bottom>

</BorderPane>