<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1350.0"
            xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.warehouse.WarehouseController"
            style="-fx-background-color: #f5f6fa;">

    <top>
        <MenuBar>
            <Menu text="Account">
                <MenuItem text="Profile"/>
                <MenuItem text="Logout" onAction="#handleLogout"/>
            </Menu>
            <Menu text="Help">
                <MenuItem text="About"/>
            </Menu>
        </MenuBar>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <Label text="Inventory Management"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <Label text="Inventory Overview"/>
            <TableView fx:id="tblSummary" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName" text="Item"/>
                    <TableColumn fx:id="colUnit" text="Unit"/>
                    <TableColumn fx:id="colTotal" text="On Hand Quantity"/>
                    <TableColumn fx:id="colExpiry" text="Nearest Expiry"/>
                    <TableColumn fx:id="colStorage" text="Storage Condition"/>
                    <TableColumn fx:id="colSummaryStatus" text="Status"/>
                </columns>
            </TableView>

            <Label text="Batch Details (FIFO)"/>
            <TableView fx:id="tblLots" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colLotId" text="Batch ID"/>
                    <TableColumn fx:id="colLotName" text="Item"/>
                    <TableColumn fx:id="colSupplier" text="Supplier"/>
                    <TableColumn fx:id="colImport" text="Received Date"/>
                    <TableColumn fx:id="colLotExpiry" text="Expiry Date"/>
                    <TableColumn fx:id="colLotStorage" text="Storage Condition"/>
                    <TableColumn fx:id="colRemain" text="Remaining Qty"/>
                    <TableColumn fx:id="colStatus" text="Status"/>
                </columns>
            </TableView>
        </VBox>
    </center>

    <right>
        <VBox spacing="12" prefWidth="300"
              style="-fx-background-color: white; -fx-border-color: #ddd;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Inventory Operations"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

            <Label text="Item Name"/>
            <TextField fx:id="txtMaterialName" promptText="e.g. Fresh Milk"/>

            <Label text="Unit"/>
            <ComboBox fx:id="cbUnit" promptText="Select unit"/>

            <Label text="Quantity"/>
            <TextField fx:id="txtQuantity" promptText="e.g. 100"/>

            <Label text="Expiry Date"/>
            <DatePicker fx:id="dpExpiryDate"/>

            <Label text="Supplier"/>
            <TextField fx:id="txtSupplierName" promptText="Enter supplier name"/>

            <Separator/>

            <Button fx:id="btnAdd" text="Stock In" maxWidth="Infinity"
                    onAction="#handleAdd"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Button fx:id="btnUpdate" text="Update Item" maxWidth="Infinity"
                    onAction="#handleUpdate"
                    style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Button fx:id="btnDelete" text="Remove Item" maxWidth="Infinity"
                    onAction="#handleDelete"
                    style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Separator/>

            <Button fx:id="btnViewRequests" text="Material Issue Requests"
                    maxWidth="Infinity"
                    onAction="#handleViewExportRequests"
                    style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold;"/>

            <Button fx:id="btnRefresh" text="Refresh"
                    maxWidth="Infinity"
                    onAction="#handleRefresh"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </VBox>
    </right>

</BorderPane>