<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="600.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.warehouse.WarehouseController">

    <!-- ================= LEFT: TABLE ================= -->
    <left>
        <TableView fx:id="tblWarehouse"
                   prefWidth="900.0"
                   BorderPane.alignment="CENTER">

            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                <TableColumn fx:id="colMaterialName" text="Tên nguyên liệu" prefWidth="220"/>
                <TableColumn fx:id="colUnit" text="Đơn vị" prefWidth="100"/>
                <TableColumn fx:id="colQuantity" text="Số lượng tồn" prefWidth="130"/>
                <TableColumn fx:id="colExpiryDate" text="Hạn sử dụng" prefWidth="150"/>
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="150"/>
                <TableColumn fx:id="colSupplier" text="Nhà cung cấp" prefWidth="180"/>
            </columns>

        </TableView>
    </left>

    <!-- ================= RIGHT: FORM ================= -->
    <right>
        <VBox spacing="15" prefWidth="250" style="-fx-padding: 15">

            <Label text="Cập nhật kho"
                   style="-fx-font-size:18; -fx-font-weight:bold;" />

            <!-- Combo chọn nguyên liệu -->
            <ComboBox fx:id="cbMaterial"
                      promptText="Chọn nguyên liệu"
                      prefHeight="40"/>

            <!-- Số lượng -->
            <TextField fx:id="txtQuantity"
                       promptText="Số lượng"
                       prefHeight="40"/>

            <!-- Hạn sử dụng -->
            <TextField fx:id="txtExpiryDate"
                       promptText="yyyy-mm-dd"
                       prefHeight="40"/>
             <TextField fx:id="txtSupplier"
           promptText="Nhập nhà cung cấp"
           prefHeight="40"/>

            <!-- Buttons -->
            <Button text="Nhập kho"
                    fx:id="btnAdd"
                    onAction="#handleAdd"
                    prefHeight="45"
                    style="-fx-background-color:#2ecc71; -fx-text-fill:white;"/>

            <Button text="Cập nhật"
                    fx:id="btnUpdate"
                    onAction="#handleUpdate"
                    prefHeight="45"
                    style="-fx-background-color:#f39c12; -fx-text-fill:white;"/>

            <Separator/>

            <Button text="Xuất kho"
                    fx:id="btnExport"
                    onAction="#handleExport"
                    prefHeight="45"
                    style="-fx-background-color:#e67e22; -fx-text-fill:white;"/>

            <Button text="Làm mới"
                    fx:id="btnRefresh"
                    onAction="#handleRefresh"
                    prefHeight="45"
                    style="-fx-background-color:#3498db; -fx-text-fill:white;"/>

        </VBox>
    </right>

    <!-- ================= TOP MENU ================= -->
    <top>
        <MenuBar>
            <Menu text="Tài khoản">
                <MenuItem text="Thông tin"/>
                <MenuItem text="Đăng xuất" onAction="#handleLogout"/>
            </Menu>
            <Menu text="Trợ giúp">
                <MenuItem text="About"/>
            </Menu>
        </MenuBar>
    </top>

</BorderPane>