<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/23"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.warehouse.ExportRequestController"
            style="-fx-background-color: #ecf0f1;">

    <center>
        <VBox spacing="12" style="-fx-padding: 15;">
            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #ddd;">
                <Label text="Danh sách yêu cầu" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                <TableView fx:id="tblRequests" style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colOrder" text="Lệnh SX" prefWidth="100"/>
                        <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Ngày yêu cầu" prefWidth="180"/>
                        <TableColumn fx:id="colNote" text="Ghi chú" prefWidth="220"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <right>
        <VBox spacing="12" prefWidth="240" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 10; -fx-background-radius: 10;">
            <Label text="⚙ Hành động" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Separator/>
            <Button text="🔍 Xem chi tiết" maxWidth="Infinity" onAction="#handleViewDetails" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="✔ Duyệt" maxWidth="Infinity" onAction="#handleApprove" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="✖ Từ chối" maxWidth="Infinity" onAction="#handleReject" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Separator/>
            <Button text="🔄 Làm mới" maxWidth="Infinity" onAction="#handleRefresh" style="-fx-background-color: #8e44ad; -fx-text-fill: white;"/>
        </VBox>
    </right>
</BorderPane>