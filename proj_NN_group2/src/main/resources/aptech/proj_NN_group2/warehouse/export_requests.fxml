<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.warehouse.ExportRequestController">

    <!-- ===== HEADER ===== -->
    <top>
        <HBox spacing="10" style="-fx-padding: 12;">
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="📦 EXPORT REQUEST MANAGEMENT" />
        </HBox>
    </top>

    <!-- ===== CENTER TABLE ===== -->
    <center>
        <VBox spacing="12">
            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <!-- Card -->
            <VBox spacing="10" style="-fx-padding: 15; -fx-background-radius: 10; -fx-border-radius: 10;">

                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Request List" />

                <TableView fx:id="tblRequests" style="-fx-background-radius: 8;">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60" text="ID" />
                        <TableColumn fx:id="colOrder" prefWidth="150" text="Production Order" />
                        <TableColumn fx:id="colStatus" prefWidth="120" text="Status" />
                        <TableColumn fx:id="colDate" prefWidth="180" text="Request Date" />
                        <TableColumn fx:id="colNote" prefWidth="220" text="Note" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

    <!-- ===== RIGHT PANEL ===== -->
    <right>
        <VBox prefWidth="240" spacing="12" style="-fx-padding: 15; -fx-border-radius: 10; -fx-background-radius: 10;">

            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="⚙ Actions" />

            <Separator />

            <Button maxWidth="Infinity" onAction="#handleViewDetails" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="🔍 View Details" />

            <Button maxWidth="Infinity" onAction="#handleApprove" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;" text="✔ Approve" />

            <Button maxWidth="Infinity" onAction="#handleReject" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;" text="✖ Reject" />

            <Separator />

            <Button maxWidth="Infinity" onAction="#handleRefresh" style="-fx-background-color: #8e44ad; -fx-text-fill: white;" text="🔄 Refresh" />

            <Button maxWidth="Infinity" onAction="#handleBack" style="-fx-background-color: #7f8c8d; -fx-text-fill: white;" text="⬅ Back" />
        </VBox>
    </right>

</BorderPane>
