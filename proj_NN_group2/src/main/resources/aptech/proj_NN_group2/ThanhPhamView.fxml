<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="850.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.ThanhPhamController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <Text text="KHO THÀNH PHẨM (KEM ĐÃ ĐÓNG HỘP)" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-fill: #1e293b;" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button onAction="#handleRefresh" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="🔄 Làm mới kho" />
               </children>
            </HBox>

            <TableView fx:id="tableThanhPham" VBox.vgrow="ALWAYS">
              <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="Mẻ ID" />
                <TableColumn fx:id="colTen" prefWidth="250.0" text="Tên Loại Kem" />
                <TableColumn fx:id="colSoLuong" prefWidth="120.0" text="Số Lượng (Hộp)" />
                <TableColumn fx:id="colNgaySX" prefWidth="180.0" text="Ngày Sản Xuất" />
                <TableColumn fx:id="colHSD" prefWidth="180.0" text="Hạn Sử Dụng" />
              </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
            </TableView>
         </children>
      </VBox>
   </children>
</AnchorPane>