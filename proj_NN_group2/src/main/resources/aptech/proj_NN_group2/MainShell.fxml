<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.MainController">
   <children>
      <VBox prefWidth="250.0" style="-fx-background-color: #1e293b;" spacing="10.0">
         <padding>
            <Insets top="30" right="15" bottom="30" left="15"/>
         </padding>
         <children>
            <HBox alignment="CENTER" spacing="10">
               <children>
                  <Text fill="WHITE" text="🍦 KEM FACTORY" style="-fx-font-weight: bold; -fx-font-size: 22px;" />
               </children>
            </HBox>
            
            <Separator prefHeight="30.0" style="-fx-opacity: 0.2;" />
            
            <Button maxWidth="Infinity" onAction="#showDashboard" styleClass="menu-button" 
                    style="-fx-background-color: #334155; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20; -fx-background-radius: 8;" text="📊  Bảng điều khiển" />
            
            <Button maxWidth="Infinity" onAction="#showSanXuat" 
                    style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20;" text="⚙️  Quy trình sản xuất" />
            
            <Button maxWidth="Infinity" onAction="#showKhoNguyenLieu" 
                    style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20;" text="📦  Kho nguyên liệu" />
            
            <Region VBox.vgrow="ALWAYS" /> <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-alignment: CENTER_LEFT;" text="👤 Đăng xuất" />
         </children>
      </VBox>

      <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS" style="-fx-background-color: #f1f5f9;">
         </StackPane>
   </children>
</HBox>