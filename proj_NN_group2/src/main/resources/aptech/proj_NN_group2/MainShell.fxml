<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<HBox prefHeight="700.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.MainController">
   <children>
      <VBox prefWidth="250.0" spacing="10.0" style="-fx-background-color: #1e293b;">
         <padding>
            <Insets bottom="30" left="15" right="15" top="30" />
         </padding>
         <children>
            <HBox alignment="CENTER" spacing="10">
               <children>
                  <Text fill="WHITE" style="-fx-font-weight: bold; -fx-font-size: 22px;" text="🍦 KEM FACTORY" />
               </children>
            </HBox>
            
            <Separator prefHeight="30.0" style="-fx-opacity: 0.2;" />
            
            <Button fx:id="btnDashboard" maxWidth="Infinity" onAction="#showDashboard" style="-fx-background-color: #334155; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20; -fx-background-radius: 8;" styleClass="menu-button" text="📊  Bảng điều khiển" />
            
            <Button fx:id="btnSanXuat" maxWidth="Infinity" onAction="#showSanXuat" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20;" text="⚙️  Quy trình sản xuất" />
            
            <Button fx:id="btnKho" maxWidth="Infinity" onAction="#showKhoNguyenLieu" style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1; -fx-alignment: CENTER_LEFT; -fx-padding: 12 20;" text="📦  Kho nguyên liệu" />
            
            <Region VBox.vgrow="ALWAYS" /> <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-alignment: CENTER_LEFT;" text="👤 Đăng xuất" />
         </children>
      </VBox>

      <StackPane fx:id="contentArea" style="-fx-background-color: #f1f5f9;" HBox.hgrow="ALWAYS">
         </StackPane>
   </children>
</HBox>
