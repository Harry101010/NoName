<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>


<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.saleman.SalemanWarehouseDashboardController">
   <center>
      <AnchorPane prefHeight="700.0" prefWidth="1100.0">
         <children>
            <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
              <tabs>
                <!-- TAB 1: LẬP PHIẾU YÊU CẦU -->
                <Tab text="1. LẬP PHIẾU YÊU CẦU">
                   <content>
                      <fx:include source="create_issue.fxml" />
                   </content>
                </Tab>
                
                  
                            
                <!-- TAB 2: THỦ KHO THÀNH PHẨM -->
                <Tab text="2. THỦ KHO THÀNH PHẨM">
                   <content>
                      <fx:include source="finished_product_warehouse.fxml" />
                   </content>
                </Tab>
              </tabs>
            </TabPane>
         </children>
      </AnchorPane>
   </center>
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Tài khoản">
            <items>
              <MenuItem mnemonicParsing="false" text="Thông tin tài khoản" />
                  <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
</BorderPane>
