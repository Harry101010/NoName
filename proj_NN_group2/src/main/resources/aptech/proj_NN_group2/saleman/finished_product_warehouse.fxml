<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 25; -fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.saleman.FinishedProductWarehouseController">
    
    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 5; -fx-background-radius: 5;">
        <Label text="YÊU CẦU XUẤT KHO CHỜ PHÊ DUYỆT" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <TableView fx:id="tableApproval" prefHeight="250">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="40" />
                <TableColumn fx:id="colOrderCode" text="Mã Đơn" prefWidth="100" />
                <TableColumn fx:id="colSaleman" text="Kinh Doanh" prefWidth="100" />
                <TableColumn fx:id="colCustomer" text="Khách Hàng" prefWidth="100" />
                <TableColumn fx:id="colProductName" text="Sản phẩm" prefWidth="120" />
                <TableColumn fx:id="colQty" text="Số lượng" prefWidth="70" />
                <TableColumn fx:id="colStatus" text="Trạng Thái" prefWidth="90" />
                <TableColumn fx:id="colAction" text="Thao tác" prefWidth="160" />
            </columns>
        </TableView>
        <Button text="Tải lại danh sách" onAction="#loadPendingNotes" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="10" prefHeight="250" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 5; -fx-background-radius: 5;">
        <HBox spacing="15" alignment="CENTER_LEFT">
            <Label text="TRA CỨU TỒN KHO THÀNH PHẨM" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="txtSearchInventory" promptText="Tìm theo tên SP hoặc mã PO..." prefWidth="300" style="-fx-padding: 8;"/>
        </HBox>
        
        <TableView fx:id="tableInventory" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colInvPO" text="Mã PO SX" prefWidth="100" />
                <TableColumn fx:id="colInvName" text="Tên Sản Phẩm" prefWidth="180" />
                <TableColumn fx:id="colInvQty" text="Tồn kho" prefWidth="80" />
                <TableColumn fx:id="colInvMfg" text="Ngày SX" prefWidth="110" />
                <TableColumn fx:id="colInvExp" text="Hạn SD" prefWidth="110" />
                <TableColumn fx:id="colInvLocation" text="Vị trí kệ" prefWidth="100" />
            </columns>
        </TableView>
    </VBox>
</VBox>