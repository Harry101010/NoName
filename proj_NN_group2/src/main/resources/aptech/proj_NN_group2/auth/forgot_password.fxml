<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aptech.proj_NN_group2.controller.auth.ForgotPasswordController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="QUÊN MẬT KHẨU" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
    <TextField fx:id="txtInput" promptText="Nhập username hoặc email" />
    <Button text="Gửi mật khẩu qua email" onAction="#handleForgotPassword" />
    <Label fx:id="lblMessage" style="-fx-text-fill: red;" />
</VBox>