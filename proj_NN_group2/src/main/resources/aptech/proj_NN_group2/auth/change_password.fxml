<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox alignment="CENTER"
      spacing="16.0"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aptech.proj_NN_group2.controller.auth.ChangePasswordController"
      style="-fx-padding: 40; -fx-background-color: #f4f4f4;">

    <children>
        <Label fx:id="lblTitle"
              text="Đổi mật khẩu"
              style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #2c3e50;" />

        <Label fx:id="lblDescription"
               text="Vui lòng nhập mật khẩu hiện tại và mật khẩu mới."
               wrapText="true"
               maxWidth="350"
               style="-fx-text-fill: #555555; -fx-font-size: 13;" />

        <VBox spacing="10.0" maxWidth="320">
            <padding>
                <Insets top="10" right="0" bottom="10" left="0"/>
            </padding>

       
            <Label text="Mật khẩu mới:" />
            <PasswordField fx:id="txtNewPassword"
                           promptText="Nhập mật khẩu mới..."
                           style="-fx-pref-height: 35;" />

            <Label text="Xác nhận mật khẩu mới:" />
            <PasswordField fx:id="txtConfirmPassword"
                           promptText="Nhập lại mật khẩu mới..."
                           style="-fx-pref-height: 35;" />
        </VBox>

        <Button text="Xác nhận đổi mật khẩu"
                onAction="#handleChangePassword"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-pref-width: 200; -fx-pref-height: 40; -fx-cursor: hand;" />
    </children>
</VBox>