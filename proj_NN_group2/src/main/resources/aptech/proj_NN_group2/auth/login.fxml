<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.auth.LoginController"
            styleClass="root">

    <center>
        <VBox alignment="CENTER" spacing="18">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <Label text="QUẢN LÝ SẢN XUẤT KEM" styleClass="page-title"/>

            <VBox spacing="10" maxWidth="320" fillWidth="true" styleClass="card">
                <TextField fx:id="txtUsername"
                           promptText="Nhập username..."
                           styleClass="input-field"/>
                <PasswordField fx:id="txtPassword"
                               promptText="Nhập mật khẩu..."
                               styleClass="input-field"/>
            </VBox>

            <Button text="Đăng nhập"
                    onAction="#handleLogin"
                    prefWidth="220"
                    prefHeight="40"
                    styleClass="primary-button"/>

            <Button text="Quên mật khẩu?"
                    onAction="#handleForgotPassword"
                    styleClass="link-button"
                    style="-fx-background-color: transparent; -fx-cursor: hand;"/>
        </VBox>
    </center>

</BorderPane>