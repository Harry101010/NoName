<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20"
      prefWidth="450"
      style="-fx-padding: 30; -fx-background-color: #ffffff;"
      xmlns="http://javafx.com/javafx/8"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aptech.proj_NN_group2.controller.auth.AccountProfileController">

    <Label text="THÔNG TIN TÀI KHOẢN"
           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
    <Separator />

    <VBox spacing="10">
        <Label text="Tên đăng nhập:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtUsername"
           editable="true"
           prefHeight="35"
           style="-fx-background-color: #f1f2f6;" />

        <Label text="Quyền hạn hiện tại:" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtRole"
                   editable="false"
                   prefHeight="35"
                   style="-fx-background-color: #f1f2f6;" />

        <Separator>
            <padding>
                <Insets top="10" bottom="10"/>
            </padding>
        </Separator>
		
		<Label text="Mật khẩu hiện tại:" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="txtCurrentPassword"
                       prefHeight="35"
                       promptText="Nhập mật khẩu hiện tại" />
		
        <Label text="Mật khẩu mới:" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="txtNewPassword"
                       prefHeight="35"
                       promptText="Nhập mật khẩu mới" />

        <Label text="Xác nhận mật khẩu mới:" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="txtConfirmPassword"
                       prefHeight="35"
                       promptText="Nhập lại mật khẩu mới" />
    </VBox>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Đóng"
                onAction="#handleClose"
                prefWidth="100"
                prefHeight="35"
                style="-fx-background-color: #bdc3c7;" />
        <Button text="Lưu thông tin"
                onAction="#handleSave"
                prefWidth="140"
                prefHeight="35"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>
</VBox>