<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.NguyenLieuController">
   <children>
      <HBox spacing="20.0" AnchorPane.bottomAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.topAnchor="15.0">
         <children>
            <VBox prefWidth="320.0" spacing="15.0" style="-fx-background-color: #f8fafc; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #e2e8f0; -fx-border-radius: 10;">
               <children>
                  <Text text="NHẬP KHO MỚI" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-fill: #1e293b;" />
                  <Separator />
                  
                  <Label text="Tên nguyên liệu:" />
                  <TextField fx:id="txtTen" promptText="VD: Sữa tươi" />
                  
                  <Label text="Nguồn gốc:" />
                  <TextField fx:id="txtNguonGoc" promptText="VD: Vinamilk" />
                  
                  <Label text="Số lượng:" />
                  <TextField fx:id="txtSoLuong" promptText="Số lượng số" />
                  
                  <Label text="Giá thành (VNĐ):" />
                  <TextField fx:id="txtGia" promptText="Giá nhập" />
                  
                  <Label text="Đơn vị tính:" />
                  <ComboBox fx:id="cbDonVi" maxWidth="Infinity" />
                  
                  <Label text="Hạn sử dụng:" />
                  <DatePicker fx:id="dpHanSD" maxWidth="Infinity" />
                  
                  <Region VBox.vgrow="ALWAYS" />
                  <Button maxWidth="Infinity" onAction="#handleThem" prefHeight="40.0" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="➕ XÁC NHẬN NHẬP KHO" />
               </children>
            </VBox>

            <VBox spacing="15.0" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <Text text="DANH SÁCH TỒN KHO" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-fill: #1e293b;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtSearch" prefWidth="220.0" promptText="🔍 Tìm tên nguyên liệu..." style="-fx-background-radius: 20;" />
                        <Button onAction="#handleRefresh" style="-fx-background-color: #3b82f6; -fx-text-fill: white;" text="🔄 Làm mới" />
                     </children>
                  </HBox>

                  <TableView fx:id="tableNguyenLieu" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="colTen" prefWidth="150.0" text="Tên Nguyên Liệu" />
                      <TableColumn fx:id="colNguonGoc" prefWidth="110.0" text="Nguồn Gốc" />
                      <TableColumn fx:id="colSoLuong" prefWidth="90.0" text="Số Lượng" />
                      <TableColumn fx:id="colDonVi" prefWidth="80.0" text="Đơn Vị" />
                      <TableColumn fx:id="colHSD" prefWidth="110.0" text="Hạn Sử Dụng" />
                      <TableColumn fx:id="colNgayNhap" prefWidth="130.0" text="Ngày Nhập" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
                  
                  <Label fx:id="lblStatus" text="Tổng số lô hàng: 0" style="-fx-font-style: italic; -fx-text-fill: #64748b;" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</AnchorPane>