<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" prefWidth="480" style="-fx-padding: 30; -fx-background-color: white;" 
      xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.admin.UserEditController">
    
    <Label text="CHỈNH SỬA THÔNG TIN NHÂN VIÊN" style="-fx-font-size: 18; -fx-font-weight: bold;" />
    <Separator />
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Tên đăng nhập:" prefWidth="120" style="-fx-font-weight: bold;" />
        <TextField fx:id="txtUsername" prefHeight="35" minWidth="250" HBox.hgrow="ALWAYS" />
    </HBox>
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Mật khẩu mới:" prefWidth="120" style="-fx-font-weight: bold;" />
        <PasswordField fx:id="txtPassword" prefHeight="35" minWidth="250" promptText="Trống nếu không đổi" HBox.hgrow="ALWAYS" />
    </HBox>
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Quyền hạn:" prefWidth="120" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="cbRole" prefHeight="35" minWidth="250" prefWidth="250" HBox.hgrow="ALWAYS" />
    </HBox>
    
    <Separator />
    
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Hủy bỏ" onAction="#handleCancel" prefWidth="100" prefHeight="35" style="-fx-background-color: #bdc3c7; -fx-cursor: hand;" />
        <Button text="Lưu thay đổi" onAction="#handleSave" prefWidth="140" prefHeight="35" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" />
    </HBox>
</VBox>