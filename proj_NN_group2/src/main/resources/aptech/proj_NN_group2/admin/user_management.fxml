<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="aptech.proj_NN_group2.controller.admin.AdminController" 
            style="-fx-padding: 0;"> <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Tài khoản">
                        <items>
                            <MenuItem text="Thông tin cá nhân" onAction="#handleOpenProfile" />
                            <SeparatorMenuItem />
                            <MenuItem text="Đăng xuất" onAction="#handleLogout" />
                        </items>
                    </Menu>
                    <Menu text="Trợ giúp">
                        <items>
                            <MenuItem text="Hướng dẫn sử dụng" />
                            <MenuItem text="About" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <VBox spacing="10" style="-fx-padding: 20 20 10 20;">
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-background-color: #ecf0f1; -fx-padding: 10; -fx-background-radius: 5;">
                    <Label fx:id="lblWelcome" text="Xin chào, Admin" style="-fx-font-weight: bold;" />
                    
                    <Button text="Hồ sơ" onAction="#handleOpenProfile" 
                            style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" />
                    
                    <Button text="Đăng xuất" onAction="#handleLogout" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" />
                </HBox>
                
                <Label text="DANH SÁCH TÀI KHOẢN NHÂN VIÊN" 
                       style="-fx-font-size: 20; -fx-font-weight: bold;" 
                       alignment="CENTER" maxWidth="Infinity">
                    <padding><Insets top="10" bottom="5"/></padding>
                </Label>
            </VBox>
        </VBox>
    </top>
    
    <center>
        <TableView fx:id="tableUsers" prefHeight="400.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="150" text="Tên đăng nhập" />
                <TableColumn fx:id="colRole" prefWidth="150" text="Quyền hạn" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Trạng thái" />
            </columns>
            <BorderPane.margin>
                <Insets left="20" bottom="20"/>
            </BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="15.0" style="-fx-padding: 0 20 20 20;">
            <Label style="-fx-font-weight: bold;" text="Thêm người dùng mới" />
            <TextField fx:id="txtNewUser" promptText="Username" />
            <PasswordField fx:id="txtNewPass" promptText="Password" />
            <ComboBox fx:id="cbRole" prefWidth="150" promptText="Chọn quyền..." />
            
            <Button text="Thêm mới" onAction="#addUser" prefWidth="150" 
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand;" />
            
            <Separator />
            
            <Button text="Khóa/Mở khóa" onAction="#toggleStatus" prefWidth="150" 
                    style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand;" />
            
            <Button fx:id="btnUpdate" onAction="#handleUpdateUser" text="Cập nhật" prefWidth="150" 
                    style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" />
            
            <Button fx:id="btnDelete" onAction="#handleDeleteUser" text="Xóa tài khoản" prefWidth="150" 
                    style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-cursor: hand;" />
        </VBox>
    </right>
</BorderPane>