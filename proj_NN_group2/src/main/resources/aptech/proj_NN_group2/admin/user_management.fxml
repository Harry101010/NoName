<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-padding: 0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.admin.AdminController"> <top>
        <VBox>
            <MenuBar>
                <menus>
                    <Menu text="Tài khoản">
                        <items>
                            <MenuItem onAction="#handleOpenProfile" text="Thông tin cá nhân" />
                            <SeparatorMenuItem />
                            <MenuItem onAction="#handleLogout" text="Đăng xuất" />
                        </items>
                    </Menu>
                    <Menu text="Trợ giúp">
                        <items>
                            <MenuItem text="Hướng dẫn sử dụng" />
                            <MenuItem text="About" />
                        </items>
                    </Menu>
                </menus>
            </MenuBar>

            <VBox spacing="10" style="-fx-padding: 20 20 10 20;">
                <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 10; -fx-background-radius: 5;">
                    <Label fx:id="lblWelcome" style="-fx-font-weight: bold;" text="Xin chào, Admin" />
                    
                    <Button onAction="#handleOpenProfile" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand;" text="Hồ sơ" />
                    
                    <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand;" text="Đăng xuất" />
                </HBox>
                
                <Label alignment="CENTER" maxWidth="Infinity" style="-fx-font-size: 20; -fx-font-weight: bold;" text="DANH SÁCH TÀI KHOẢN NHÂN VIÊN">
                    <padding><Insets bottom="5" top="10" /></padding>
                </Label>
            </VBox>
        </VBox>
    </top>
    
    <center>
        <TableView fx:id="tableUsers" prefHeight="400.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="150" text="Tên đăng nhập" />
                <TableColumn fx:id="colRole" prefWidth="150" text="Quyền hạn" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Trạng thái" />
            </columns>
            <BorderPane.margin>
                <Insets bottom="20" left="20" />
            </BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="15.0" style="-fx-padding: 0 20 20 20;">
            <Label style="-fx-font-weight: bold;" text="Thêm người dùng mới" />
            <TextField fx:id="txtNewUser" promptText="Username" />
            <PasswordField fx:id="txtNewPass" promptText="Password" />
            <ComboBox fx:id="cbRole" prefWidth="150" promptText="Chọn quyền..." />
            
            <Button onAction="#addUser" prefWidth="150" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand;" text="Thêm mới" />
            
            <Separator />
            
            <Button onAction="#toggleStatus" prefWidth="150" style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand;" text="Khóa/Mở khóa" />
            
            <Button fx:id="btnUpdate" onAction="#handleUpdateUser" prefWidth="150" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Cập nhật" />
            
            <Button fx:id="btnDelete" onAction="#handleDeleteUser" prefWidth="150" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-cursor: hand;" text="Xóa tài khoản" />
        </VBox>
    </right>
</BorderPane>
