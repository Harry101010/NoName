<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-padding: 20;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.AdminController">
    
    <center>
        <TableView fx:id="tableUsers" prefHeight="400.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="50" text="ID" />
                <TableColumn fx:id="colUsername" prefWidth="150" text="Tên đăng nhập" />
                <TableColumn fx:id="colRole" prefWidth="150" text="Quyền hạn" />
                <TableColumn fx:id="colStatus" prefWidth="100" text="Trạng thái" />
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="15.0" style="-fx-padding: 0 0 0 20;">
            <Label style="-fx-font-weight: bold;" text="Thêm người dùng mới" />
            <TextField fx:id="txtNewUser" promptText="Username" />
            <PasswordField fx:id="txtNewPass" promptText="Password" />
            <ComboBox fx:id="cbRole" prefWidth="150" promptText="Chọn quyền..." />
            
            <Button onAction="#addUser" prefWidth="150" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" text="Thêm mới" />
            <Separator />
            <Button onAction="#toggleStatus" prefWidth="150" style="-fx-background-color: #e67e22; -fx-text-fill: white;" text="Khóa/Mở khóa" />
        </VBox>
    </right>
   <top>
      <MenuBar prefHeight="26.0" prefWidth="234.0" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Tài khoản">
            <items>
              <MenuItem fx:id="userInfo" mnemonicParsing="false" text="Thông tin cá nhân" />
                  <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Trợ giúp">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
</BorderPane>
