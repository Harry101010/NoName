<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="aptech.proj_NN_group2.controller.AdminController" style="-fx-padding: 20;">
    <top>
        <Label text="DANH SÁCH TÀI KHOẢN NHÂN VIÊN" style="-fx-font-size: 20; -fx-font-weight: bold;" BorderPane.alignment="CENTER">
            <padding><Insets bottom="20"/></padding>
        </Label>
    </top>
    
    <center>
        <TableView fx:id="tableUsers" prefHeight="400.0" prefWidth="600.0">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colUsername" text="Tên đăng nhập" prefWidth="150" />
                <TableColumn fx:id="colRole" text="Quyền hạn" prefWidth="150" />
                <TableColumn fx:id="colStatus" text="Trạng thái" prefWidth="100" />
            </columns>
        </TableView>
    </center>

    <right>
        <VBox spacing="15.0" style="-fx-padding: 0 0 0 20;">
            <Label text="Thêm người dùng mới" style="-fx-font-weight: bold;" />
            <TextField fx:id="txtNewUser" promptText="Username" />
            <PasswordField fx:id="txtNewPass" promptText="Password" />
            <ComboBox fx:id="cbRole" promptText="Chọn quyền..." prefWidth="150" />
            
            <Button text="Thêm mới" onAction="#addUser" prefWidth="150" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />
            <Separator />
            <Button text="Khóa/Mở khóa" onAction="#toggleStatus" prefWidth="150" style="-fx-background-color: #e67e22; -fx-text-fill: white;" />
        </VBox>
    </right>
</BorderPane>