<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.DashboardController">
   <children>
      <VBox spacing="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
         <children>
            <Text text="BẢNG ĐIỀU KHIỂN SẢN XUẤT" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-fill: #1a202c;" />
            
            <HBox spacing="30.0">
               <children>
                  <VBox prefHeight="120.0" prefWidth="250.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;">
                     <children>
                        <Label text="Mẻ kem hôm nay" textFill="#718096" />
                        <Label fx:id="lblTongMeKem" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold;" textFill="#3182ce" />
                     </children>
                  </VBox>

                  <VBox prefHeight="120.0" prefWidth="250.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 20;">
                     <children>
                        <Label text="Nguyên liệu sắp hết" textFill="#718096" />
                        <Label fx:id="lblCanhBaoKho" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold;" textFill="#e53e3e" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox spacing="10.0" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 20;">
               <children>
                  <Label text="DANH SÁCH NGUYÊN LIỆU CẦN NHẬP GẤP" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
                  <ListView fx:id="lvNguyenLieuSapHet" prefHeight="250.0" />
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</AnchorPane>