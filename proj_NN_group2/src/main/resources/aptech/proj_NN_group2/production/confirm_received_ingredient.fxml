<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="aptech.proj_NN_group2.controller.production.ConfirmReceivedIngredientController"
      style="-fx-background-color: #f4f6f8;">
    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Button text="← Quay lại" onAction="#goBack"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 6;"/>
        <Label text="Xác Nhận Nhận Nguyên Liệu">
            <font><Font name="System Bold" size="18"/></font>
        </Label>
    </HBox>

    <!-- Bảng phiếu xuất kho chờ xác nhận -->
    <TitledPane text="Phiếu xuất kho đã duyệt — chờ Trưởng SX xác nhận" collapsible="false"
                style="-fx-background-color: white;">
        <VBox spacing="8">
            <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
            <HBox spacing="8">
                <Button text="🔄 Làm mới" onAction="#handleRefresh"
                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-background-radius: 6;"/>
            </HBox>
            <TableView fx:id="tableReceipts" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colReceiptId"     text="ID Phiếu XK"  prefWidth="90"/>
                    <TableColumn fx:id="colIceCream"      text="Loại kem"      prefWidth="160"/>
                    <TableColumn fx:id="colKg"            text="Số kg"         prefWidth="80"/>
                    <TableColumn fx:id="colReceiptStatus" text="Trạng thái"    prefWidth="110"/>
                    <TableColumn fx:id="colCreatedAt"     text="Ngày tạo"      prefWidth="160"/>
                    <TableColumn fx:id="colNote"          text="Ghi chú"       prefWidth="180"/>
                </columns>
                <placeholder><Label text="Không có phiếu xuất kho nào đang chờ xác nhận"/></placeholder>
            </TableView>
        </VBox>
    </TitledPane>

    <!-- Thông tin phiếu đang chọn -->
    <HBox spacing="8" alignment="CENTER_LEFT"
          style="-fx-background-color: #e8f4fd; -fx-padding: 8 12; -fx-background-radius: 6;">
        <Label text="Đang chọn:" style="-fx-font-weight: bold;"/>
        <Label fx:id="lblSelectedInfo" style="-fx-text-fill: #0056b3;"/>
    </HBox>

    <!-- Bảng chi tiết nguyên liệu -->
    <TitledPane text="Chi tiết nguyên liệu trong phiếu" collapsible="false"
                style="-fx-background-color: white;">
        <VBox spacing="6">
            <padding><Insets top="8" right="12" bottom="8" left="12"/></padding>
            <TableView fx:id="tableDetails" prefHeight="160">
                <columns>
                    <TableColumn fx:id="colIngredient" text="Nguyên liệu"       prefWidth="220"/>
                    <TableColumn fx:id="colUnit"       text="Đơn vị"            prefWidth="100"/>
                    <TableColumn fx:id="colQty"        text="Số lượng cần nhận" prefWidth="160"/>
                </columns>
                <placeholder><Label text="Chọn phiếu xuất kho để xem chi tiết nguyên liệu"/></placeholder>
            </TableView>
        </VBox>
    </TitledPane>

    <!-- Nút xác nhận -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="✔ Xác nhận đã nhận đủ nguyên liệu" onAction="#handleConfirm"
                prefHeight="42"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6;"/>
    </HBox>

    <Label fx:id="lblMessage" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
</VBox>