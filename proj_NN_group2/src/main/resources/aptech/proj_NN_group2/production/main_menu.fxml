<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.production.MainMenuController">

    <!-- TOP: Header bar -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="16"
                  style="-fx-background-color: #1e40af; -fx-padding: 14 24;">
                <Label text="🍦 IceCream Production System"
                       style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Production Manager"
                       fx:id="lblUserInfo"
                       style="-fx-text-fill: #bfdbfe; -fx-font-size: 13px;"/>
                <MenuBar style="-fx-background-color: transparent; -fx-padding: 0;">
                    <Menu text="Account" style="-fx-text-fill: white;">
                        <MenuItem text="Logout" onAction="#handleLogout"/>
                    </Menu>
                </MenuBar>
            </HBox>
            <!-- Sub header -->
            <HBox style="-fx-background-color: #1d4ed8; -fx-padding: 6 24;">
                <Label text="Welcome back! Select a module to get started."
                       style="-fx-text-fill: #93c5fd; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </top>

    <!-- CENTER: Module cards -->
    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #f1f5f9; -fx-padding: 60 80;">

            <Label text="Production Dashboard"
                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Manage your ice cream production workflow"
                   style="-fx-font-size: 14px; -fx-text-fill: #64748b; -fx-padding: 4 0 32 0;"/>

            <HBox spacing="20" alignment="CENTER">

                <!-- Card 1: Production Management -->
                <VBox spacing="12" alignment="CENTER"
                      prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-padding: 28; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-cursor: hand;">
                    <Label text="🏭" style="-fx-font-size: 36px;"/>
                    <Label text="Production Management"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                    <Label text="Create orders, track stages,&#10;manage ingredients"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                    <Button text="Open →" onAction="#goToProductionDashboard"
                            styleClass="primary-button"
                            style="-fx-font-size: 13px; -fx-padding: 8 20;"/>
                </VBox>

                <!-- Card 2: Recipe Management -->
                <VBox spacing="12" alignment="CENTER"
                      prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #e2e8f0; -fx-padding: 28; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 10, 0, 0, 4); -fx-cursor: hand;">
                    <Label text="📋" style="-fx-font-size: 36px;"/>
                    <Label text="Recipe Management"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                    <Label text="Define ingredients and&#10;quantities per product"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b; -fx-text-alignment: center; -fx-wrap-text: true;" maxWidth="200"/>
                    <Button text="Open →" onAction="#goToRecipeManagement"
                            style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-font-size: 13px; -fx-padding: 8 20;"/>
                </VBox>

            </HBox>

        </VBox>
    </center>

    <!-- BOTTOM: Footer -->
    <bottom>
        <HBox alignment="CENTER"
              style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-padding: 10;">
            <Label text="IceCream Production System v1.0  •  © 2026"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
