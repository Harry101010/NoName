<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="aptech.proj_NN_group2.controller.production.RecipeManagementController"
            fitToWidth="true">

    <content>
        <VBox spacing="16" prefWidth="1400">
            <padding>
                <Insets top="14" right="14" bottom="14" left="14"/>
            </padding>
            

            <Label text="Quản lý công thức"
                   style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

            <TabPane tabClosingPolicy="UNAVAILABLE">

                <Tab text="Sản phẩm kem">
                    <content>
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="10">
                                <padding>
                                    <Insets top="12" right="12" bottom="12" left="12"/>
                                </padding>

                                <Label text="Tên kem" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="txtIceCreamName" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Đang hoạt động" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <CheckBox fx:id="chkIceCreamActive" selected="true" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="0" GridPane.columnSpan="4">
                                    <Button text="Xóa trắng" onAction="#newIceCream"/>
                                    <Button text="Lưu" onAction="#saveIceCream"/>
                                    <Button text="Xóa" onAction="#deleteIceCream"/>
                                    <Button text="Tải lại" onAction="#refreshAll"/>
                                </HBox>
                            </GridPane>

                            <TableView fx:id="tblIceCream" prefHeight="320">
                                <columns>
                                    <TableColumn fx:id="colIceCreamId" text="ID" prefWidth="80"/>
                                    <TableColumn fx:id="colIceCreamName" text="Tên kem" prefWidth="500"/>
                                    <TableColumn fx:id="colIceCreamActive" text="Đang hoạt động" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Nguyên liệu">
                    <content>
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="10">
                                <padding>
                                    <Insets top="12" right="12" bottom="12" left="12"/>
                                </padding>

                                <Label text="Tên nguyên liệu" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <TextField fx:id="txtIngredientName" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Nguồn gốc" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <TextField fx:id="txtIngredientOrigin" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Điều kiện bảo quản" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="txtStorageCondition" prefWidth="260" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <Label text="Đơn vị" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                                <ComboBox fx:id="cboUnit" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="3"/>

                                <Label text="Giá / đơn vị" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                                <TextField fx:id="txtPricePerUnit" prefWidth="180" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                                <Label text="Đang hoạt động" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                                <CheckBox fx:id="chkIngredientActive" selected="true" GridPane.rowIndex="2" GridPane.columnIndex="3"/>

                                <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="4">
                                    <Button text="Xóa trắng" onAction="#newIngredient"/>
                                    <Button text="Lưu" onAction="#saveIngredient"/>
                                    <Button text="Xóa" onAction="#deleteIngredient"/>
                                    <Button text="Tải lại" onAction="#refreshAll"/>
                                </HBox>
                            </GridPane>

                            <TableView fx:id="tblIngredient" prefHeight="320">
                                <columns>
                                    <TableColumn fx:id="colIngredientId" text="ID" prefWidth="70"/>
                                    <TableColumn fx:id="colIngredientName" text="Nguyên liệu" prefWidth="220"/>
                                    <TableColumn fx:id="colIngredientOrigin" text="Nguồn gốc" prefWidth="180"/>
                                    <TableColumn fx:id="colIngredientStorage" text="Bảo quản" prefWidth="220"/>
                                    <TableColumn fx:id="colIngredientUnitId" text="Unit ID" visible="false"/>
                                    <TableColumn fx:id="colIngredientUnitName" text="Đơn vị" prefWidth="100"/>
                                    <TableColumn fx:id="colIngredientPrice" text="Giá" prefWidth="100"/>
                                    <TableColumn fx:id="colIngredientActive" text="Đang hoạt động" prefWidth="90"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Chi tiết công thức">
                    <content>
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="10">
                                <padding>
                                    <Insets top="12" right="12" bottom="12" left="12"/>
                                </padding>

                                <Label text="Kem" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="cboRecipeIceCream" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Nguyên liệu" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <ComboBox fx:id="cboRecipeIngredient" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Label text="Số lượng / 1kg" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                                <TextField fx:id="txtQuantityPerKg" prefWidth="160" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                                <HBox spacing="10" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="4">
                                    <Button text="Xóa trắng" onAction="#newRecipe"/>
                                    <Button text="Lưu" onAction="#saveRecipe"/>
                                    <Button text="Xóa" onAction="#deleteRecipe"/>
                                    <Button text="Tải lại" onAction="#refreshAll"/>
                                </HBox>
                            </GridPane>

                            <TableView fx:id="tblRecipe" prefHeight="360">
                                <columns>
                                    <TableColumn fx:id="colRecipeId" text="ID" prefWidth="80"/>
                                    <TableColumn fx:id="colRecipeIceCreamName" text="Tên kem" prefWidth="250"/>
                                    <TableColumn fx:id="colRecipeIngredientName" text="Nguyên liệu" prefWidth="250"/>
                                    <TableColumn fx:id="colRecipeUnitName" text="Đơn vị" prefWidth="120"/>
                                    <TableColumn fx:id="colRecipeQtyPerKg" text="SL / kg" prefWidth="120"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </content>
                </Tab>

                <Tab text="Tính toán sản xuất">
                    <content>
                        <VBox spacing="10">
                            <GridPane hgap="10" vgap="10">
                                <padding>
                                    <Insets top="12" right="12" bottom="12" left="12"/>
                                </padding>

                                <Label text="Kem" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                                <ComboBox fx:id="cboCalcIceCream" prefWidth="280" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                                <Label text="Số kg đầu ra" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                                <TextField fx:id="txtCalcOutputKg" prefWidth="120" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                                <Button text="Tính toán" onAction="#calculateRecipe" GridPane.rowIndex="0" GridPane.columnIndex="4"/>
                            </GridPane>

                            <TextArea fx:id="txtCalcResult" prefRowCount="18" wrapText="true"/>
                        </VBox>
                    </content>
                </Tab>

            </TabPane>
        </VBox>
    </content>
</ScrollPane>