<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="377.0" prefWidth="1076.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="aptech.proj_NN_group2.controller.production.WarehouseController">
   <left>
        <TableView fx:id="tblWarehouse" prefHeight="508.0" prefWidth="900.0" style="-fx-background-color: white; -fx-border-color: #d9d9d9; -fx-border-width: 1;" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="colMaterialName" prefWidth="230.0" text="Tên nguyên liệu" />
                <TableColumn fx:id="colUnit" prefWidth="120.0" text="Đơn vị" />
                <TableColumn fx:id="colQuantity" prefWidth="140.0" text="Số lượng tồn" />
                <TableColumn fx:id="colExpiryDate" prefWidth="170.0" text="Hạn sử dụng" />
                <TableColumn fx:id="colStatus" prefWidth="160.0" text="Trạng thái" />
            </columns>
        </TableView>
   </left>

   <right>
        <VBox prefHeight="378.0" prefWidth="176.0" spacing="18.0" BorderPane.alignment="CENTER">
            <children>
                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #222222;" text="Cập nhật kho" />

                <TextField fx:id="txtMaterialName" prefHeight="42.0" promptText="Tên nguyên liệu"
                           style="-fx-background-color: white; -fx-border-color: #cfcfcf; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 14px;" />

                <TextField fx:id="txtQuantity" prefHeight="42.0" promptText="Số lượng"
                           style="-fx-background-color: white; -fx-border-color: #cfcfcf; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 14px;" />

                <TextField fx:id="txtExpiryDate" prefHeight="42.0" promptText="Hạn sử dụng (yyyy-mm-dd)"
                           style="-fx-background-color: white; -fx-border-color: #cfcfcf; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 14px;" />

                <ComboBox fx:id="cbUnit" prefHeight="42.0" prefWidth="260.0" promptText="Chọn đơn vị..."
                          style="-fx-background-color: white; -fx-border-color: #cfcfcf; -fx-border-radius: 4; -fx-background-radius: 4; -fx-font-size: 14px;" />

                <Button fx:id="btnAdd" mnemonicParsing="false" onAction="#handleAdd" prefHeight="48.0" prefWidth="260.0"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 4;"
                        text="Nhập kho" />

                <Button fx:id="btnUpdate" mnemonicParsing="false" onAction="#handleUpdate" prefHeight="48.0" prefWidth="260.0"
                        style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 4;"
                        text="Cập nhật tồn kho" />

                <Separator prefWidth="260.0" />

                <Button fx:id="btnExport" mnemonicParsing="false" onAction="#handleExport" prefHeight="44.0" prefWidth="260.0"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 4;"
                        text="Xuất kho" />

                <Button fx:id="btnRefresh" mnemonicParsing="false" onAction="#handleRefresh" prefHeight="44.0" prefWidth="260.0"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 4;"
                        text="Làm mới" />
            </children>
            <padding>
                <Insets bottom="0.0" left="0.0" right="0.0" top="0.0" />
            </padding>
        </VBox>
   </right>

   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Tài khoản">
            <items>
              <MenuItem mnemonicParsing="false" text="Thông tin tài khoản" />
              <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
            </items>
          </Menu>
          <Menu mnemonicParsing="false" text="Trợ giúp">
            <items>
              <MenuItem mnemonicParsing="false" text="About" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
</BorderPane>