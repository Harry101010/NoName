<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.production_stage.ProductionTrackingController"
      stylesheets="@../css/style.css"> <padding>
        <Insets bottom="15" left="15" right="15" top="15" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="MA TRẬN THEO DÕI SẢN XUẤT" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <Button text="🔄 Làm mới dữ liệu" onAction="#refreshMatrix" style="-fx-background-color: #007bff; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="tblProductionMatrix" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colOrderId" prefWidth="80.0" text="OrderID" />
            <TableColumn fx:id="colProductName" prefWidth="180.0" text="Sản phẩm" />
        </columns>
        <placeholder>
            <Label text="Không có đơn hàng nào đang sản xuất" />
        </placeholder>
    </TableView>
    
</VBox>