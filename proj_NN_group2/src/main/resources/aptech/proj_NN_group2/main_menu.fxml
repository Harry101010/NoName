<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="aptech.proj_NN_group2.controller.MainMenuController">
   <center>
      <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #f4f6f8;">
          <padding>
            <Insets bottom="40" left="60" right="60" top="40" />
         </padding>
      
          <Label style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Ice Cream Management" />
          <Label style="-fx-text-fill: #888;" text="DUY - Production Module" />
      
          <Button onAction="#goToCreateBatch" prefHeight="45" prefWidth="250" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Tạo Mẻ Sản Xuất" />
      
          <Button onAction="#goToProductionProcess" prefHeight="45" prefWidth="250" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Theo Dõi Công Đoạn" />
      
          <Button onAction="#goToIngredientIssueRequest" prefHeight="45" prefWidth="250" style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Yêu Cầu Xuất Kho Nguyên Liệu" />
      
          <Button onAction="#goToConfirmReceivedIngredient" prefHeight="45" prefWidth="250" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Xác Nhận Nhận Nguyên Liệu" />
      
          <Button onAction="#goToStageDetail" prefHeight="45" prefWidth="250" style="-fx-background-color: #00BCD4; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;" text="Chi Tiết Công Đoạn Sản Xuất" />
      </VBox>
   </center>
   <top>
      <MenuBar BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Tài khoản">
            <items>
              <MenuItem mnemonicParsing="false" onAction="#goToProfile" text="Thông tin tài khoản" />
                  <MenuItem mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
            </items>
          </Menu>
        </menus>
      </MenuBar>
   </top>
</BorderPane>
