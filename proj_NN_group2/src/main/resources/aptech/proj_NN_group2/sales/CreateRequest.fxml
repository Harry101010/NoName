<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.sales.CreateRequestController">
    <padding>
        <Insets top="15" right="20" bottom="15" left="20"/>
    </padding>

    <TitledPane text="New Delivery Request" collapsible="false">
        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
            </columnConstraints>

            <Label text="Customer:"/>
            <TextField fx:id="txtCustomer" promptText="Name" GridPane.columnIndex="1"/>

            <Label text="Product:" GridPane.columnIndex="2"/>
            <ComboBox fx:id="cbProduct" promptText="Select" prefWidth="300" GridPane.columnIndex="3"/>

            <Label text="Quantity (kg):" GridPane.rowIndex="1"/>
            <TextField fx:id="txtQty" promptText="0.0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

            <Label text="Notes:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            <TextField fx:id="txtNotes" promptText="Urgent..." GridPane.columnIndex="3" GridPane.rowIndex="1"/>

            <Button text="Submit Request" onAction="#handleSubmit" prefWidth="150"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" 
                    GridPane.columnIndex="3" GridPane.rowIndex="2"/>
        </GridPane>
	    </TitledPane>
	
	   <HBox spacing="10" alignment="CENTER_LEFT">
		    <Label text="MY REQUEST HISTORY" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
		    <Button text="Refresh" onAction="#handleRefresh" 
		            style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
		</HBox>		
		
	<TableView fx:id="tblMyRequests" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" text="Date Requested" prefWidth="150"/>
            <TableColumn fx:id="colId" text="Req ID" prefWidth="70"/>
            <TableColumn fx:id="colCustomer" text="Customer" prefWidth="180"/>
            <TableColumn fx:id="colProduct" text="Product" prefWidth="150"/>
            <TableColumn fx:id="colQty" text="Qty" prefWidth="80"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
    <Label fx:id="lblMsg" style="-fx-text-fill: red;" />
</VBox>