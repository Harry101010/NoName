<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.sales.SalemanController"
      style="-fx-background-color: #ecf0f1;">
    
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;" VBox.vgrow="NEVER">
        <Label text="1. TẠO PHIẾU YÊU CẦU XUẤT THÀNH PHẨM" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        
        <HBox spacing="20">
            <VBox spacing="10" prefWidth="380" style="-fx-padding: 15; -fx-background-color: #f8f9fa; -fx-border-color: #e0e0e0; -fx-border-radius: 5; -fx-background-radius: 5;">
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    
                    <Label text="Khách hàng:" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtCustomerName" promptText="Tên khách hàng" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Mã đơn:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                    <TextField fx:id="txtOrderCode" promptText="VD: PO-XXXX" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    
                    <Label text="Ngày giao:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                    <DatePicker fx:id="dpDeliveryDate" promptText="Chọn ngày..." GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>
                </GridPane>
                
                <Separator/>
                
                <VBox spacing="8">
                    <Label text="Chọn sản phẩm &amp; Số lượng" style="-fx-font-weight: bold;"/>
                    <ComboBox fx:id="cbProducts" maxWidth="Infinity" promptText="-- Chọn loại kem --"/>
                    <HBox spacing="10">
                        <TextField fx:id="txtQuantity" promptText="Số lượng (kg)" HBox.hgrow="ALWAYS"/>
                        <Button text="Thêm vào bảng" onAction="#addItemToTable" minWidth="110" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
                
                <Region VBox.vgrow="ALWAYS" /> 
                
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Làm mới" onAction="#handleClear" minWidth="80" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-cursor: hand;" />
                    <Button text="GỬI YÊU CẦU" onAction="#handleSaveNote" HBox.hgrow="ALWAYS" maxWidth="Infinity" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label text="Danh sách sản phẩm xuất kho:" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                <TableView fx:id="tableTempDetails" prefHeight="240" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colProductName" text="Tên sản phẩm" prefWidth="250" />
                        <TableColumn fx:id="colQuantity" text="Số lượng (kg)" prefWidth="120" />
                        <TableColumn fx:id="colAction" text="Thao tác" prefWidth="100" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </HBox>
    </VBox>

    <Separator style="-fx-padding: 5 0;"/>

    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #bdc3c7; -fx-border-radius: 5; -fx-background-radius: 5;" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="2. LỊCH SỬ PHIẾU YÊU CẦU" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Tải lại dữ liệu" onAction="#loadHistory" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold;"/>
        </HBox>
        
        <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colHistoryId" text="ID" prefWidth="40" />
                <TableColumn fx:id="colHistoryOrderCode" text="Mã Đơn" prefWidth="90" />
                <TableColumn fx:id="colHistorySaleman" text="Nhân Viên" prefWidth="120" /> 
                <TableColumn fx:id="colHistoryCustomer" text="Khách Hàng" prefWidth="130" />
                <TableColumn fx:id="colHistoryProductName" text="Sản phẩm" prefWidth="130" />
                <TableColumn fx:id="colHistoryProductQty" text="Số lượng" prefWidth="80" />
                <TableColumn fx:id="colHistoryCreateDate" text="Ngày Lập" prefWidth="110" />
                <TableColumn fx:id="colHistoryDeliveryDate" text="Ngày Giao" prefWidth="90" />
                <TableColumn fx:id="colHistoryStatus" text="Trạng Thái" prefWidth="100" />
                <TableColumn fx:id="colHistoryAction" text="Thao tác" prefWidth="120" />
            </columns>
        </TableView>
    </VBox>
</VBox>