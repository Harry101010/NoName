<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.sales.DispatchHistoryController">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="FINISHED GOODS DISPATCH HISTORY" 
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="txtSearchHistory" promptText="Search by Order ID or Customer..." prefWidth="350"/>
        <Button text="Export Report" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
    	<Button fx:id="btnRefresh" text="Refresh" onAction="#handleRefresh"/>
    </HBox>

    <TableView fx:id="tableHistory" VBox.vgrow="ALWAYS" style="-fx-font-size: 13px;">
        <columns>
            <TableColumn fx:id="colDate" text="Dispatch Date (VN)" prefWidth="150" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colOrderId" text="Order ID" prefWidth="80" style="-fx-alignment: CENTER; -fx-font-weight: bold;"/>
            <TableColumn fx:id="colProduct" text="Product" prefWidth="180"/>
            <TableColumn fx:id="colQty" text="Qty Issued" prefWidth="100" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colStatus" text="Quality Status" prefWidth="130" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colMfg" text="Mfg Date" prefWidth="120" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colCustomer" text="Destination (Customer)" prefWidth="180"/>
            <TableColumn fx:id="colNotes" text="Remarks" prefWidth="200"/>
        </columns>
    </TableView>
</VBox>