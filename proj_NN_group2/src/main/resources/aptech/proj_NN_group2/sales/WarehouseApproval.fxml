<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/8" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="aptech.proj_NN_group2.controller.sales.WarehouseApprovalController">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="WAREHOUSE DISPATCH APPROVAL" 
               style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Refresh List" onAction="#loadPendingRequests" 
                style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="tblPending" VBox.vgrow="ALWAYS" style="-fx-font-size: 14px;">
        <columns>
            <TableColumn fx:id="colId" text="Req ID" prefWidth="80" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colCustomer" text="Customer" prefWidth="200"/>
            <TableColumn fx:id="colProduct" text="Product Name" prefWidth="200"/>
            <TableColumn fx:id="colQty" text="Requested Qty" prefWidth="120" style="-fx-alignment: CENTER-RIGHT;"/>
            <TableColumn fx:id="colDate" text="Request Date" prefWidth="150" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100" style="-fx-alignment: CENTER;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox spacing="15.0" alignment="CENTER_RIGHT">
        <Label text="Quality Status: " style="-fx-font-weight: bold;"/>
        <ComboBox fx:id="cbQuality" prefWidth="150">
             </ComboBox>
        
        <Button text="Reject Request" onAction="#handleReject" 
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
        
        <Button text="Approve &amp; Dispatch (FIFO)" onAction="#handleApprove" 
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>
    </HBox>
</VBox>